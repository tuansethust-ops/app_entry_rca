{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "final_leaf.schema.json",
  "type": "object",
  "required": [
    "id",
    "mapped_leaf_ids",
    "status",
    "causality",
    "confidence",
    "symptom",
    "location",
    "mechanism",
    "origin",
    "ownership",
    "action",
    "local_delta_ms",
    "nested_deltas_ms",
    "overlap_group",
    "additive"
  ],
  "properties": {
    "id": {"type": "string"},
    "mapped_leaf_ids": {"type": "array", "items": {"type": "string"}},
    "status": {"type": "string"},
    "causality": {"enum": ["DIRECT", "CONTRIBUTING", "CORRELATION_ONLY", "REJECTED"]},
    "confidence": {"enum": ["HIGH", "MEDIUM", "LOW"]},
    "local_delta_ms": {"type": ["number", "null"]},
    "exclusive_contribution_ms": {"type": ["number", "null"]},
    "nested_deltas_ms": {"type": "object", "additionalProperties": {"type": "number"}},
    "overlap_group": {"type": "string"},
    "additive": {"type": "boolean"},
    "delta_note": {"type": "string"},
    "verification_plan": {"type": "object"}
  },
  "additionalProperties": true
}
